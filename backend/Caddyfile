# Global server options
# SLH-DSA-SHA2-128f produces ~22.5 KB Authorization headers.
# Set max_header_size to 64 KB — matches gateway ReadBufferSize.
{
	servers {
		max_header_size 64KB
	}
}

(tasktify_app) {
	root * /srv
	encode zstd gzip

	@api path /api/* /health
	reverse_proxy @api gateway:3000 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}

		# Keep benchmark endpoints streaming during long signing runs.
		flush_interval -1

		transport http {
			keepalive 30s
			keepalive_idle_conns 100
		}
	}

	@assets path *.js *.css *.woff *.woff2 *.png *.jpg *.jpeg *.gif *.webp *.svg *.ico
	header @assets Cache-Control "public, max-age=31536000, immutable"

	@frontend not path /api/* /health
	try_files @frontend {path} /index.html

	file_server

	log {
		output file /data/logs/access.log {
			roll_size 10mb
			roll_keep 5
		}
	}
}

(common_headers) {
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		X-XSS-Protection "0"
		Referrer-Policy "strict-origin-when-cross-origin"
		Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; img-src 'self' data:; font-src 'self' data:; style-src 'self'; script-src 'self'; connect-src 'self'"
		Cross-Origin-Opener-Policy "same-origin"
		Cross-Origin-Resource-Policy "same-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), fullscreen=(self)"
		-Server
	}
}

(production_headers) {
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		X-XSS-Protection "0"
		Referrer-Policy "strict-origin-when-cross-origin"
		Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; img-src 'self' data:; font-src 'self' data:; style-src 'self'; script-src 'self'; connect-src 'self'; upgrade-insecure-requests"
		Cross-Origin-Opener-Policy "same-origin"
		Cross-Origin-Resource-Policy "same-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), fullscreen=(self)"
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		-Server
	}
}

http://localhost, http://127.0.0.1 {
	import tasktify_app
	import common_headers
}

poc-ridwanmuh3.my.id {
	import tasktify_app
	import production_headers
}
